<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Window 1: FFT Heat Map -->
    <FrameLayout
        android:id="@+id/fftContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <com.example.fftt01.FFTHeatMapView
            android:id="@+id/fftHeatMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111" />

        <com.example.fftt01.CropOverlayView
            android:id="@+id/cropOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <!-- Window 2: Controls and EQ -->
    <LinearLayout
        android:id="@+id/controlsWindow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="4dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline">

        <LinearLayout
            android:id="@+id/saveEscContainer"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:weightSum="3"
            android:visibility="gone">
            <Button
                android:id="@+id/btnSaveInRow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:text="SAVE"
                android:backgroundTint="#90EE90"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_margin="4dp" />
            <Button
                android:id="@+id/btnEscInRow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="ESC"
                android:backgroundTint="#FFA500"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_margin="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/micAndColorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:layout_marginBottom="2dp"
            android:orientation="horizontal"
            android:weightSum="100">
            <Spinner
                android:id="@+id/micSpinner"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="65"
                android:layout_marginEnd="2dp"
                android:gravity="center_vertical"
                android:padding="0dp" />
            <Spinner
                android:id="@+id/colorSpinner"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="35"
                android:layout_marginStart="2dp"
                android:gravity="center_vertical"
                android:padding="0dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mainButtonsLayout"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:weightSum="100"
            android:layout_marginBottom="2dp">

            <Button
                android:id="@+id/btnLatency"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="60"
                android:text="Latency"
                android:backgroundTint="#D3D3D3"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="20"
                android:text="GALLERY"
                android:backgroundTint="#FFFF00"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnQuit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="20"
                android:text="QUIT"
                android:backgroundTint="#FF0000"
                android:textColor="#FFFFFF"
                android:layout_margin="1dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/eqContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="90">

            <LinearLayout
                android:id="@+id/eqSlidersLayout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="50"
                android:orientation="horizontal"
                android:weightSum="50">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="100\nHz" android:textColor="#FFFFFF" android:textSize="10sp" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/eq100"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtEqValue100" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="300\nHz" android:textColor="#FFFFFF" android:textSize="10sp" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/eq300"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtEqValue300" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="1k\nHz" android:textColor="#FFFFFF" android:textSize="10sp" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/eq1k"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtEqValue1k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="3k\nHz" android:textColor="#FFFFFF" android:textSize="10sp" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/eq3k"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtEqValue3k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="8k\nHz" android:textColor="#FFFFFF" android:textSize="10sp" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/eq8k"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtEqValue8k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Double width gutter between EQ and Filter (weight 2) -->
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" />

            <!-- Filter Sliders (3 sliders, each weight 10, total 32 including gutters) -->
            <LinearLayout
                android:id="@+id/filterControlsLayout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="32"
                android:orientation="horizontal"
                android:weightSum="32">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:text="Filter  Rise   Fall\n%   Time   Time" android:textColor="#00FFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp" android:lines="2" android:includeFontPadding="false"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/sliderNoiseFilter"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="0.0" android:valueTo="1.0" android:value="0.0" android:stepSize="0.01"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="false"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtFilterValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\n%" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:textColor="#00FFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp" android:lines="2" android:includeFontPadding="false"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/sliderNoiseRise"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="0.0" android:valueTo="3.0" android:value="1.7" android:stepSize="0.01"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="false"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtRiseValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\nms" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="10"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="32dp" android:textColor="#00FFFF" android:textSize="7sp" android:textStyle="bold" android:gravity="bottom|center_horizontal" android:paddingBottom="2dp" android:lines="2" android:includeFontPadding="false"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider app:trackCornerSize="0dp"
                            android:id="@+id/sliderNoiseFall"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:valueFrom="0.0" android:valueTo="3.0" android:value="2.3" android:stepSize="0.01"
                            android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="false"
                            app:trackHeight="32dp" app:thumbRadius="16dp" app:thumbColor="#FFFFFF"
                            app:trackColorActive="#00FFFF" app:trackColorInactive="#007F7F"
                            android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtFallValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\nms" android:textColor="#000000" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>