<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <com.example.fftt01.WaveletView
        android:id="@+id/waveletView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/waveletGuidelineLand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintDimensionRatio="1:1" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/waveletGuidelineLand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.4" />

    <LinearLayout
        android:id="@+id/waveletControls"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="4dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/waveletGuidelineLand"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:weightSum="3"
            android:layout_marginBottom="2dp">

            <Button
                android:id="@+id/btnWaveletBack"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="ESC"
                android:backgroundTint="#FFA500"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FAM" android:textColor="#FFFF00" android:textSize="10sp" android:textStyle="bold"/>
                <Spinner
                    android:id="@+id/waveletFamilySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:backgroundTint="#FFFFFF"
                    android:layout_margin="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BND" android:textColor="#FFFF00" android:textSize="10sp" android:textStyle="bold"/>
                <Spinner
                    android:id="@+id/waveletBoundarySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:backgroundTint="#FFFFFF"
                    android:layout_margin="1dp" />
            </LinearLayout>
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:rowCount="2"
            android:paddingHorizontal="2dp">

            <CheckBox
                android:id="@+id/checkSoftThresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOFT"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="9sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="2dp" />

            <CheckBox
                android:id="@+id/checkWPT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WPT"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="9sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="2dp" />

            <CheckBox
                android:id="@+id/checkCWT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CWT"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="9sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="2dp" />

            <CheckBox
                android:id="@+id/checkLogScale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOG"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="9sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="2dp" />

            <CheckBox
                android:id="@+id/checkLocalNorm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="L-NORM"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="9sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="2dp" />

            <CheckBox
                android:id="@+id/checkReconstruct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECON"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF"
                android:textSize="9sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="2dp" />

            <Button
                android:id="@+id/btnWaveletStop"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_columnSpan="2"
                android:layout_gravity="fill_horizontal"
                android:text="QUIT"
                android:backgroundTint="#FF0000"
                android:textColor="#FFFFFF"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5"
            android:layout_marginTop="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="LVL" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderLevel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="1.0"
                        android:valueTo="8.0"
                        android:value="4.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="88dp"
                        app:thumbRadius="44dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#00FFFF"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtLevelValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="ORD" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderOrder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="1.0"
                        android:valueTo="10.0"
                        android:value="1.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="88dp"
                        app:thumbRadius="44dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#00FFFF"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtOrderValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="FS" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderSampling"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="1000.0"
                        android:valueTo="44100.0"
                        android:value="44100.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="88dp"
                        app:thumbRadius="44dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#AAAAAA"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtSamplingValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="44k" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="THR" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="0.0"
                        android:valueTo="1.0"
                        android:value="0.1"
                        android:stepSize="0.001"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="88dp"
                        app:thumbRadius="44dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#FF00FF"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtThresholdValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.1" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="CLR" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderColor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="0.0"
                        android:valueTo="3.0"
                        android:value="0.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="88dp"
                        app:thumbRadius="44dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#AAAAAA"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center" />
                    <TextView android:id="@+id/txtColorValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Def" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
