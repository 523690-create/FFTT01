<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <com.example.fftt01.FFTHeatMapView
        android:id="@+id/viewerFft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#111111"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/viewerGuideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintDimensionRatio="1:1" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/viewerGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.4" />

    <LinearLayout
        android:id="@+id/viewerControls"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="4dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/viewerGuideline"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:weightSum="5"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnViewerBack"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="ESC"
                android:backgroundTint="#FFA500"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnViewerPlay"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="PLAY"
                android:backgroundTint="#90EE90"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnViewerFilter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="FILTER"
                android:backgroundTint="#0000FF"
                android:textColor="#FFFFFF"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnViewerSweep"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="SWEEP\nOFF"
                android:backgroundTint="#FF69B4"
                android:textColor="#FFFFFF"
                android:layout_margin="1dp"
                android:maxLines="2"
                android:textSize="7sp"
                android:textStyle="bold"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnViewerWavelet"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="WAVE"
                android:backgroundTint="#FFFF00"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:padding="0dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="8">

            <!-- EQ Group -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="4.5"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EQUALIZER"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:gravity="center"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:weightSum="5">
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="100" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="center"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <com.google.android.material.slider.Slider android:id="@+id/vEq100" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                                <TextView android:id="@+id/txtEq100Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                            </FrameLayout>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="300" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="center"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <com.google.android.material.slider.Slider android:id="@+id/vEq300" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                                <TextView android:id="@+id/txtEq300Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                            </FrameLayout>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="1k" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="center"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <com.google.android.material.slider.Slider android:id="@+id/vEq1k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                                <TextView android:id="@+id/txtEq1kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                            </FrameLayout>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="3k" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="center"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <com.google.android.material.slider.Slider android:id="@+id/vEq3k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                                <TextView android:id="@+id/txtEq3kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                            </FrameLayout>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="8k" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="center"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <com.google.android.material.slider.Slider android:id="@+id/vEq8k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" android:stepSize="10.0" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                                <TextView android:id="@+id/txtEq8kValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#444444" android:layout_marginHorizontal="2dp"/>

            <!-- FFT Group -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2.5"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FFT"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:gravity="center"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="SIZE" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <com.google.android.material.slider.Slider android:id="@+id/vFftSize" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="4.0" android:value="3.0" android:stepSize="1.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#AAAAAA" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                                <TextView android:id="@+id/txtFftSizeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2048" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                            </FrameLayout>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="STEP" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                                <com.google.android.material.slider.Slider android:id="@+id/vFftStep" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="4.0" android:value="2.0" android:stepSize="1.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#AAAAAA" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                                <TextView android:id="@+id/txtFftStepValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1024" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#444444" android:layout_marginHorizontal="2dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="COLOR" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold" android:gravity="center"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/vColor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:valueFrom="0.0"
                        android:valueTo="3.0"
                        android:value="0.0"
                        android:stepSize="1.0"
                        android:orientation="vertical"
                        app:labelBehavior="gone"
                        app:trackHeight="88dp"
                        app:thumbRadius="44dp"
                        app:thumbColor="#FFFFFF"
                        app:trackColorActive="#AAAAAA"
                        app:trackColorInactive="#333333"
                        android:layout_gravity="center"/>
                    <TextView android:id="@+id/txtVColorName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Def" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="center" android:elevation="4dp"/>
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
