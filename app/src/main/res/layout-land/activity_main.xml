<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Sidebar for controls: Left side -->
    <LinearLayout
        android:id="@+id/vSidebar"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/fftContainer"
        app:layout_constraintHorizontal_weight="0.4"
        android:clipChildren="false">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_listening"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btnQuitTop"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_quit"
                android:backgroundTint="#FF0000"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_gallery"
                android:backgroundTint="#FFFF00"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/controlsOverlayRoot"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/sliderContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:weightSum="54"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- EQ Sliders Only -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_100hz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                        <com.google.android.material.slider.Slider android:id="@+id/eq100" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"/>
                        <TextView android:id="@+id/txtEqValue100" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_300hz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                        <com.google.android.material.slider.Slider android:id="@+id/eq300" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"/>
                        <TextView android:id="@+id/txtEqValue300" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_1khz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                        <com.google.android.material.slider.Slider android:id="@+id/eq1k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"/>
                        <TextView android:id="@+id/txtEqValue1k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_3khz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                        <com.google.android.material.slider.Slider android:id="@+id/eq3k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"/>
                        <TextView android:id="@+id/txtEqValue3k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="10" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false">
                    <TextView android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="0.3" android:text="@string/label_8khz" android:textColor="#FFFFFF" android:textSize="8sp" android:gravity="bottom|center_horizontal"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.7" android:clipChildren="false" android:clipToPadding="false">
                        <com.google.android.material.slider.Slider android:id="@+id/eq8k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="24dp" app:thumbRadius="12dp" app:trackColorActive="#00FF00" app:trackColorInactive="#007F00"/>
                        <TextView android:id="@+id/txtEqValue8k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_0db" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:layout_gravity="top|center_horizontal" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Save/Esc Superimposed -->
            <LinearLayout
                android:id="@+id/saveEscContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#DD000000"
                android:visibility="gone">
                <Button
                    android:id="@+id/btnSaveInRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_save"
                    android:backgroundTint="#90EE90"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_margin="8dp" />
                <Button
                    android:id="@+id/btnEscInRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_esc"
                    android:backgroundTint="#FFA500"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:layout_margin="8dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Hidden controls in landscape -->
        <View android:id="@+id/micAndColorLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/mainButtonsLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/filterControlsLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/btnLatency" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/micSpinner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/colorSpinner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/sliderNoiseFilter" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/sliderNoiseRise" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
        <View android:id="@+id/sliderNoiseFall" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    </LinearLayout>

    <!-- Map Area: Right side, Square 1:1 -->
    <FrameLayout
        android:id="@+id/fftContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_weight="0.6">

        <com.example.fftt01.FFTHeatMapView
            android:id="@+id/fftHeatMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111" />

        <com.example.fftt01.CropOverlayView
            android:id="@+id/cropOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Placeholder guideline -->
    <View android:id="@+id/guideline" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</androidx.constraintlayout.widget.ConstraintLayout>
