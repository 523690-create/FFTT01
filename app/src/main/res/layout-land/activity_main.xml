<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Window 1: FFT Heat Map -->
    <FrameLayout
        android:id="@+id/fftContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <com.example.fftt01.FFTHeatMapView
            android:id="@+id/fftHeatMap"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111" />

        <com.example.fftt01.CropOverlayView
            android:id="@+id/cropOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />
    </FrameLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.4" />

    <!-- Window 2: Controls and EQ -->
    <LinearLayout
        android:id="@+id/controlsWindow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="4dp"
        android:background="#222222"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/saveEscContainer"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal"
            android:weightSum="2"
            android:visibility="gone">
            <Button
                android:id="@+id/btnSaveInRow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="SAVE"
                android:backgroundTint="#90EE90"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_margin="1dp" />
            <Button
                android:id="@+id/btnEscInRow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="ESC"
                android:backgroundTint="#FFA500"
                android:textColor="#000000"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_margin="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/micAndColorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp"
            android:weightSum="2">
            <Spinner
                android:id="@+id/micSpinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#FFFFFF"
                android:padding="4dp" />
            <Button
                android:id="@+id/btnLatency"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Latency"
                android:backgroundTint="#D3D3D3"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mainButtonsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnFilterMode"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="FILTER"
                android:backgroundTint="#0000FF"
                android:textColor="#FFFFFF"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEqualizerMode"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="EQUALIZER"
                android:backgroundTint="#00FF00"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="GALLERY"
                android:backgroundTint="#FFFF00"
                android:textColor="#000000"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnQuit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="QUIT"
                android:backgroundTint="#FF0000"
                android:textColor="#FFFFFF"
                android:layout_margin="1dp"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/eqContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/eqSlidersLayout"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5"
                    android:orientation="horizontal"
                    android:weightSum="5">

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="100" android:textColor="#FFFFFF" android:textSize="8sp"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/eq100" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtEqValue100" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="300" android:textColor="#FFFFFF" android:textSize="8sp"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/eq300" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtEqValue300" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="1k" android:textColor="#FFFFFF" android:textSize="8sp"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/eq1k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtEqValue1k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="3k" android:textColor="#FFFFFF" android:textSize="8sp"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/eq3k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtEqValue3k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="8k" android:textColor="#FFFFFF" android:textSize="8sp"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/eq8k" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="-40.0" android:valueTo="40.0" android:value="0.0" android:stepSize="10.0" android:orientation="vertical" app:labelBehavior="gone" app:tickVisible="true" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FF00" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtEqValue8k" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\ndB" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/filterControlsLayout"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:visibility="gone">

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="FLTR %" android:textColor="#00FFFF" android:textSize="8sp" android:textStyle="bold"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/sliderNoiseFilter" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="1.0" android:value="0.0" android:stepSize="0.01" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtFilterValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\n%" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="RISE" android:textColor="#00FFFF" android:textSize="8sp" android:textStyle="bold"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/sliderNoiseRise" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.01" android:valueTo="1.0" android:value="0.015" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtRiseValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\nms" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="FALL" android:textColor="#00FFFF" android:textSize="8sp" android:textStyle="bold"/>
                        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <com.google.android.material.slider.Slider android:id="@+id/sliderNoiseFall" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.01" android:valueTo="1.0" android:value="0.05" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#00FFFF" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                            <TextView android:id="@+id/txtFallValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0\nms" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="16dp" android:text="CLR" android:textColor="#FFFFFF" android:textSize="8sp" android:textStyle="bold"/>
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <com.google.android.material.slider.Slider android:id="@+id/sliderColor" android:layout_width="match_parent" android:layout_height="match_parent" android:valueFrom="0.0" android:valueTo="3.0" android:value="0.0" android:stepSize="1.0" android:orientation="vertical" app:labelBehavior="gone" app:trackHeight="88dp" app:thumbRadius="44dp" app:thumbColor="#FFFFFF" app:trackColorActive="#AAAAAA" app:trackColorInactive="#333333" android:layout_gravity="center"/>
                        <TextView android:id="@+id/txtColorName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Def" android:textColor="#000000" android:textSize="8sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:elevation="4dp"/>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
